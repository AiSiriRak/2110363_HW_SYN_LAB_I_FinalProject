# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y16 [get_cells pclk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y2 [get_cells clkgen/clk__0/inst/clkf_buf]
set_property LOC BUFGCTRL_X0Y1 [get_cells clkgen/clk__0/inst/clkout1_buf]
set_property LOC BUFGCTRL_X0Y0 [get_cells clkgen/clk__0/inst/clkout2_buf]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X0Y128 [get_cells xclk_cam_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X1Y26 [get_ports clk]
set_property LOC IOB_X0Y126 [get_ports pclk]

# Clock net "pclk_IBUF_BUFG" driven by instance "pclk_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y16"
#startgroup
create_pblock {CLKAG_pclk_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_pclk_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="pclk_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_pclk_IBUF_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "clkgen/clk__0/inst/clk_out25" driven by instance "clkgen/clk__0/inst/clkout1_buf" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_clkgen/clk__0/inst/clk_out25}
add_cells_to_pblock [get_pblocks  {CLKAG_clkgen/clk__0/inst/clk_out25}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clkgen/clk__0/inst/clk_out25"}]]]
resize_pblock [get_pblocks {CLKAG_clkgen/clk__0/inst/clk_out25}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "clkgen/clk__0/inst/clk_out24" driven by instance "clkgen/clk__0/inst/clkout2_buf" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_clkgen/clk__0/inst/clk_out24}
add_cells_to_pblock [get_pblocks  {CLKAG_clkgen/clk__0/inst/clk_out24}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=xclk_cam_OBUF_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clkgen/clk__0/inst/clk_out24"}]]]
